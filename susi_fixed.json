      "name": "Transcribir Audio",
      "type": "@n8n/n8n-nodes-langchain.googleGemini",
      "typeVersion": 1.2,
      "position": [896, 160],
      "credentials": {
        "googlePalmApi": {"id": "InzYRDhfDgJFmwlQ", "name": "Google Gemini(PaLM) Api account"}
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\nconst j = items[0].json || {};\nlet text = '';\ntry { text = j.content.parts[0].text || ''; } catch(e) {}\nif (!text) { text = j.text || j.transcription || ''; }\ntext = (text || '').toString().trim();\nconst chat_id = ($execution.customData.get('chat_id') || '').toString();\nif (!text) return [{ json: { text: '[No se pudo transcribir el audio; intenta de nuevo o escribe el mensaje]', chat_id } }];\nreturn [{ json: { text, chat_id } }];"
      },
      "id": "1250cc7b-a532-47bf-9e88-37f329d35efa",
      "name": "Texto desde Voz",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 160]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\nreturn [{ json: { text: items[0].json.text || '', chat_id: items[0].json.chat_id || '' } }];"
      },
      "id": "c1",
      "name": "Set Texto Directo",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1120, 352]
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nif (items.length === 0) return [];\nconst text = items[0].json.text || '';\nconst chat_id = items[0].json.chat_id || '';\nif (!text || !chat_id) return [];\nconst now = new Date();\nconst pad = n => String(n).padStart(2, '0');\nconst fmt = d => `${d.getFullYear()}/${pad(d.getMonth()+1)}/${pad(d.getDate())}`;\nconst fmtISO = d => `${d.getFullYear()}-${pad(d.getMonth()+1)}-${pad(d.getDate())}`;\nconst yest = new Date(now.getTime() - 86400000);\nconst tmrw = new Date(now.getTime() + 86400000);\nreturn [{ json: {\n  text, chat_id, session_id: chat_id,\n  today: fmt(now), yesterday: fmt(yest), tomorrow: fmt(tmrw),\n  todayISO: fmtISO(now), yesterdayISO: fmtISO(yest), tomorrowISO: fmtISO(tmrw)\n} }];"
      },
