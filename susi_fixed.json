    {
      "parameters": {
        "jsCode": "const msg = $input.item.json.message || {};\nconst chatId = (msg.chat && msg.chat.id ? msg.chat.id : '').toString();\nconst text = msg.text || msg.caption || '';\nconst voice = msg.voice || msg.audio;\nconst isVoice = !!voice;\n$execution.customData.set('chat_id', chatId);\nreturn [{ json: { chat_id: chatId, text, is_voice: isVoice, file_id: voice ? voice.file_id : '' }, binary: $input.item.binary || {} }];"
      },
      "id": "a2",
      "name": "Extraer Mensaje",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [224, 256]
    },
